SUMMARY="A simple but powerful template language for C++"
DESCRIPTION="This library provides an easy to use and lightning fast text templating system to \
use with C++ programs.

It was originally called Google Templates, due to its origin as the template system used for \
Google search result pages. Now it has a more general name matching its community-owned nature."
HOMEPAGE="https://github.com/OlafvdSpek/ctemplate"
COPYRIGHT="2005 Google Inc."
LICENSE="BSD (3-clause)"
REVISION="1"
srcGitRev="20474e9c91ebe35643c9df52541ad76e297cca11"
SOURCE_URI="https://github.com/OlafvdSpek/ctemplate/archive/$srcGitRev.tar.gz"
CHECKSUM_SHA256="81f64092acb5b8da090c91edb86007d7261c2a12589ae74ec589648480e494a3"
SOURCE_DIR="ctemplate-$srcGitRev"

ARCHITECTURES="all !x86_gcc2"
SECONDARY_ARCHITECTURES="x86"

libVersion="3.0.0"
libVersionCompat="$libVersion compat >= ${libVersion%%.*}"

PROVIDES="
	ctemplate$secondaryArchSuffix = $portVersion
	cmd:diff_tpl_auto_escape
	cmd:make_tpl_varnames_h
	cmd:template_converter
	lib:libctemplate$secondaryArchSuffix = $libVersionCompat
	lib:libctemplate_nothreads$secondaryArchSuffix = $libVersionCompat
	"
REQUIRES="
	haiku$secondaryArchSuffix
	"

PROVIDES_devel="
	ctemplate${secondaryArchSuffix}_devel = $portVersion
	devel:libctemplate$secondaryArchSuffix = $libVersionCompat
	devel:libctemplate_nothreads$secondaryArchSuffix = $libVersionCompat
	"
REQUIRES_devel="
	ctemplate$secondaryArchSuffix == $portVersion base
	"

BUILD_REQUIRES="
	haiku${secondaryArchSuffix}_devel
	"
BUILD_PREREQUIRES="
	cmd:aclocal
	cmd:autoreconf
	cmd:gcc$secondaryArchSuffix
	cmd:libtoolize$secondaryArchSuffix
	cmd:make
	cmd:perl
	cmd:pkg_config$secondaryArchSuffix
	cmd:python3
	"

BUILD()
{
	autoreconf -fi
	runConfigure ./configure --disable-static
	make $jobArgs
}

INSTALL()
{
	make install

	# remove libtools files
	rm -f $libDir/*.la

	prepareInstalledDevelLibs \
		libctemplate \
		libctemplate_nothreads
	fixPkgconfig

	packageEntries devel \
		$developDir
}

TEST()
{
# Testsuite summary for ctemplate 2.3
# TOTAL: 20
# PASS:  18
# FAIL:  2
	make check
}
