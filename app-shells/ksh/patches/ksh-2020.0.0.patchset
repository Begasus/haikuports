From 021b991443240a1ebf9425c390bca09c449119c0 Mon Sep 17 00:00:00 2001
From: begasus <begasus@gmail.com>
Date: Sat, 13 Jun 2020 21:50:30 +0000
Subject: Fix4


diff --git a/src/cmd/ksh93/cmds/uname.c b/src/cmd/ksh93/cmds/uname.c
index e165eac..9cfb0ea 100644
--- a/src/cmd/ksh93/cmds/uname.c
+++ b/src/cmd/ksh93/cmds/uname.c
@@ -168,18 +168,12 @@ int b_uname(int argc, char **argv, Shbltin_t *context) {
     if (flags & OPT_hostid) {
 #if _mem_idnumber_utsname
         sep = output(sep, flags, OPT_hostid, ut.idnumber, "hostid");
-#else
-        sfsprintf(buf, sizeof(buf), "%08x", gethostid());
-        sep = output(sep, flags, OPT_hostid, buf, "hostid");
 #endif
     }
     if (flags & OPT_domain) {
 #if AST_SUNOS
         // TODO: Fix this for Solaris.
         sep = output(sep, flags, OPT_domain, "domain.unknown", "domain");
-#else
-        getdomainname(buf, sizeof(buf));
-        sep = output(sep, flags, OPT_domain, buf, "domain");
 #endif
     }
     if (sep) sfputc(sfstdout, '\n');
-- 
