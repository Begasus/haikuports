      * missing messages
      */
+#if _LIBCPP_HAS_CATOPEN
     cp->messages = dtopen(&state.message_disc, Dtset);
     if (cp->messages) {
         n = m = 0;
@@ -221,6 +222,7 @@ static Catalog_t *init(char *s) {
         }
     }
     catclose(d);
+#endif // _LIBCPP_HAS_CATOPEN
     return cp;
 }
 
@@ -360,7 +362,9 @@ char *translate(const char *loc, const char *cmd, const char *cat, const char *m
     if (cp->locale != loc || cp->nlspath != nlspath) {
         cp->locale = loc;
         cp->nlspath = nlspath;
+#if _LIBCPP_HAS_CATOPEN
         if (cp->cat != NOCAT) catclose(cp->cat);
+#endif
         if ((cp->cat = find(cp->locale, cp->name)) == NOCAT) {
             cp->debug = !strcmp(cp->locale, "debug");
         } else {
@@ -382,7 +386,9 @@ char *translate(const char *loc, const char *cmd, const char *cat, const char *m
          * get the translated message
          */
 
+#if _LIBCPP_HAS_CATOPEN
         r = catgets(cp->cat, mp->set, mp->seq, msg);
+#endif
         if (r != (char *)msg) {
             if (!strcmp(r, (char *)msg)) {
                 r = (char *)msg;
